# Copy this file to .env and update values for your environment.

# Database: examples:
# - SQLite (dev): sqlite+aiosqlite:///./dev.db
# - Postgres (prod): postgresql+asyncpg://user:password@host:5432/dbname
DATABASE_URL=postgresql+asyncpg://syllabiq_user:strongpassword@localhost:5432/syllabiq_dev
DATABASE_SUPERUSER_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/postgres
AUTO_CREATE_DB=true

# JWT settings
JWT_SECRET=change_this_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_SECONDS=86400

# CORS origins (comma-separated). In .env, this will be interpreted as a Python list by pydantic if using quotes.
# For local dev allowing all origins, you can leave as ["*"]
CORS_ALLOW_ORIGINS=["*"]

# RAG: LLM and embedding provider (openai | ollama). Default openai.
LLM_PROVIDER=openai
# Optional: openai | ollama. If unset, follows LLM_PROVIDER. Changing provider may require re-indexing ChromaDB.
# EMBEDDING_PROVIDER=openai

# OpenAI (when LLM_PROVIDER or EMBEDDING_PROVIDER is openai): API key and model names (env for quick config)
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Ollama (when LLM_PROVIDER or EMBEDDING_PROVIDER is ollama): base URL and model names (env for quick config)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ChromaDB persistence directory for vector store
CHROMA_PERSIST_DIR=./chroma_data

# Max upload size in MB for topic content (PDF, CSV, DOCX)
UPLOAD_MAX_SIZE_MB=10

